# ============================================================
# timing_constraints.xdc — Clock and I/O timing constraints
# NOTE: Port names use "_0" suffix as generated by BD wrapper
# ============================================================

create_clock -name sys_clk -period 20.000 [get_ports sys_clk_0]
set_property IOSTANDARD LVCMOS33 [get_ports sys_clk_0]

create_generated_clock -name adc_clk -source [get_clocks sys_clk] -multiply_by 16 -divide_by 25 [get_ports adc_clk_0]
create_generated_clock -name ref_clk_10m -source [get_clocks sys_clk] -multiply_by 16 -divide_by 80 [get_ports ref_clk_10m_0]

create_clock -name pps_clk -period 1000000000.000 [get_ports pps_clk_0]
set_clock_uncertainty -setup 0.500 [get_clocks pps_clk]
set_clock_uncertainty -hold  0.500 [get_clocks pps_clk]

set adc_period 31.250
set conv_delay_max [expr 3 * $adc_period + 25.0]
set_input_delay -clock adc_clk -max $conv_delay_max [get_ports {ad_data_0[7:0]}]
set_input_delay -clock adc_clk -max $conv_delay_max [get_ports ad_otr_0]
set_input_delay -clock adc_clk -min 10.0 [get_ports {ad_data_0[7:0]}]

set_clock_uncertainty -setup 0.300 [get_clocks sys_clk]
set_clock_uncertainty -hold  0.150 [get_clocks sys_clk]
set_clock_uncertainty -setup 0.500 [get_clocks ref_clk_10m]
set_clock_uncertainty -hold  0.500 [get_clocks ref_clk_10m]

set_property MIN_PULSE_WIDTH 2ns [get_ports {pulse_0_0 pulse_1_0 pulse_2_0 pulse_3_0}]
set_false_path -from [get_clocks sys_clk] -to [get_clocks pps_clk]
